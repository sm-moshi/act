{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":preserveSemverRanges",
    "helpers:pinGitHubActionDigests",
    ":disableRateLimiting"
  ],
  "baseBranchPatterns": ["develop"],
  "rebaseWhen": "conflicted",
  "rangeStrategy": "bump",
  "enabledManagers": ["gomod", "github-actions", "dockerfile", "mise", "woodpecker"],
  "ignorePaths": ["docs/**/vendor/**", "**/vendor/**", "**/testdata/**"],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies",
      "groupSlug": "go-deps",
      "separateMinorPatch": true,
      "labels": ["dependencies", "go"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions",
      "separateMinorPatch": true,
      "labels": ["dependencies", "ci"]
    },
    {
      "matchManagers": ["dockerfile"],
      "groupName": "Docker images",
      "groupSlug": "docker-images",
      "separateMinorPatch": true,
      "labels": ["dependencies", "docker"]
    },
    {
      "matchManagers": ["mise"],
      "groupName": "Mise tools",
      "groupSlug": "mise-tools",
      "separateMinorPatch": true,
      "labels": ["dependencies", "tooling"]
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major"],
      "dependencyDashboardApproval": true
    },
    {
      "matchDepTypes": ["indirect"],
      "matchManagers": ["gomod"],
      "labels": ["dependencies", "go", "indirect"],
      "prPriority": -1
    },
    {
      "description": "Docker CLI/Engine major upgrades require manual code migration (moby module split)",
      "matchPackageNames": [
        "github.com/docker/cli",
        "github.com/docker/docker"
      ],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
